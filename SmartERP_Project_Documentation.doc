    <!-- PAGE 2: TABLE OF CONTENTS & EXECUTIVE SUMMARY -->
    <h1>Table of Contents</h1>
    <ol style="font-size: 12.0pt; line-height: 2.0;">
        <li>Executive Summary &amp; Overview</li>
        <li>System Architecture &amp; Technology Stack</li>
        <li>Database Schema &amp; PostgreSQL Specifications</li>
        <li>User Authentication &amp; Onboarding Gateways</li>
        <li>Company Profile &amp; Entity Workspace</li>
        <li>Masters Directory: Ledgers &amp; Stock Registry</li>
        <li>Transaction &amp; Billing Engines</li>
        <li>Reports Hub, Data Exports &amp; Printing</li>
